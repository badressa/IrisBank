# .env.example — IRISBANK
# Copiez ce fichier en .env et remplissez les valeurs

# ─── APPLICATION ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── BASE DE DONNÉES ────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=banque_db

SESSION_SECRET=irisbanksecret

